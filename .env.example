# Cloud Configuration Template
# Copy this to .env and fill in your values
# DO NOT COMMIT THIS FILE TO VERSION CONTROL

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Artifact Registry Configuration
ARTIFACT_REGISTRY_LOCATION=us-central1
ARTIFACT_REGISTRY_REPOSITORY=containers

# Confluence Configuration
CONFLUENCE_URL=https://your-confluence-domain.atlassian.net
CONFLUENCE_USERNAME=your-email@example.com
CONFLUENCE_API_TOKEN=your-api-token
CONFLUENCE_SPACE_KEY=YOUR_SPACE_KEY
CONFLUENCE_PAGE_TITLE=Container Vulnerability Report

# Scanner Configuration
MAX_VULNERABILITY_SEVERITY=HIGH
SCAN_BATCH_SIZE=10
TRIVY_PATH=trivy

# Scheduling
SCAN_SCHEDULE_CRON=0 2 * * *
ENABLE_SCHEDULING=true

# Logging
LOG_LEVEL=INFO
